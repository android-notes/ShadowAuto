<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/configRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/configPage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:id="@+id/configBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/config_title"
                android:textColor="@color/text"
                android:textSize="32sp" />

            <ImageButton
                android:id="@+id/configCloseButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_button"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/text"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/configCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_icon_bubble"
                    android:gravity="center"
                    android:text="@string/ai_badge"
                    android:textColor="@color/primary_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:text="@string/model_service"
                    android:textColor="@color/text"
                    android:textSize="21sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/apiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_input"
                android:hint="@string/api_key_hint"
                android:inputType="textPassword"
                android:minHeight="54dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColorHint="@color/muted"
                android:textColor="@color/text"
                android:textSize="17sp" />

            <AutoCompleteTextView
                android:id="@+id/apiBase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="@string/api_url_hint"
                android:inputType="textUri"
                android:minHeight="54dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColorHint="@color/muted"
                android:textColor="@color/text"
                android:textSize="17sp" />

            <Spinner
                android:id="@+id/modelSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:minHeight="54dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/modelStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/model_empty_status"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <Button
                android:id="@+id/testButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/button_primary"
                android:minHeight="48dp"
                android:text="@string/test_connection_save"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/cancelConfigButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_secondary"
                android:minHeight="48dp"
                android:text="@string/back"
                android:textAllCaps="false"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
